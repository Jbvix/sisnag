PORT=3000

# Origens permitidas no browser (front Netlify → API Railway). Lista separada por vírgula ou *.
# Ex.: https://sisnag.netlify.app
CORS_ORIGIN=*

# Grok (xAI) — obtenha a chave em https://console.x.ai/
# Pode usar GROK_API_KEY ou XAI_API_KEY (ambos são aceites no código).
GROK_API_KEY=
# XAI_API_KEY=

GROK_API_BASE_URL=https://api.x.ai/v1
GROK_CHAT_MODEL=grok-2-latest
GROK_VISION_MODEL=grok-2-vision-latest

# Marine Traffic: apenas embed no browser (sem MARINETRAFFIC_API_KEY).
# Centro inicial do embed segue o mapa Leaflet ao abrir o painel.
