# Em local, o PORT é 3000 por defeito. Na Railway o PORT é definido pela plataforma.
PORT=3000

# Origens CORS (front Netlify → API Railway). Uma ou várias URLs separadas por vírgula; o servidor remove a barra final.
# Deve coincidir com o que o browser envia no header Origin (sem / no fim). * ou vazio = permitir qualquer origem.
# Ex.: https://sisnag.netlify.app
CORS_ORIGIN=*

# Escuta (Railway / Docker). Por defeito o servidor usa 0.0.0.0
# HOST=0.0.0.0

# Grok (xAI) — obtenha a chave em https://console.x.ai/
# Pode usar GROK_API_KEY ou XAI_API_KEY (ambos são aceites no código).
GROK_API_KEY=
# XAI_API_KEY=

GROK_API_BASE_URL=https://api.x.ai/v1
GROK_CHAT_MODEL=grok-2-latest
GROK_VISION_MODEL=grok-2-vision-latest

# Marine Traffic: apenas embed no browser (sem MARINETRAFFIC_API_KEY).
# Centro inicial do embed segue o mapa Leaflet ao abrir o painel.
